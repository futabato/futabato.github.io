---
import BootSequence from '../components/BootSequence.astro';
import CircuitBackground from '../components/CircuitBackground.astro';
import OzLayer from '../components/OzLayer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = "futabato's portfolio — Data Scientist interested in CyberSecurity.", ogImage = '/icon.jpg' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <!-- OGP -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:site_name" content="futabato" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@01futabato10" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!--オタクくん見てる～～～？-->
    <!-- Boot sequence overlay -->
    <BootSequence />
    <!-- SVG noise filter (referenced by NoiseOverlay) -->
    <svg style="position:absolute;width:0;height:0;" aria-hidden="true">
      <filter id="noise">
        <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" />
        <feColorMatrix type="saturate" values="0" />
      </filter>
    </svg>

    <!-- Watch Dogs inspired circuit board background -->
    <CircuitBackground />

    <!-- Summer Wars OZ third layer -->
    <OzLayer />

    <slot />

    <!-- Film grain canvas -->
    <canvas id="film-grain" aria-hidden="true"></canvas>

    <!-- VHS tracking bands -->
    <div class="vhs-tracking" id="vhs-tracking-1" aria-hidden="true"></div>
    <div class="vhs-tracking" id="vhs-tracking-2" aria-hidden="true"></div>

    <!-- VHS timestamp -->
    <div class="vhs-timestamp" aria-hidden="true">
      <div class="vhs-rec"><span class="vhs-rec__dot"></span> REC</div>
      <div id="vhs-date"></div>
    </div>
    <!-- Console Easter Egg -->
    <script>
      console.log(
        '%cIntrusion detected.',
        'color: #ff0000; font-size: 14px; font-weight: bold; font-family: monospace;'
      );
      console.log(
        '%cYour session has been logged.\n' +
        'IP: ' + Math.floor(Math.random()*255) + '.' + Math.floor(Math.random()*255) + '.' + Math.floor(Math.random()*255) + '.' + Math.floor(Math.random()*255) + '\n' +
        'Fingerprint: 0x' + Array.from({length:12}, () => Math.floor(Math.random()*16).toString(16)).join('').toUpperCase() + '\n' +
        'Timestamp: ' + new Date().toISOString(),
        'color: #888880; font-size: 11px; font-family: monospace;'
      );
      console.log(
        '%cオタクくんならDevTools開くと思っていたよ。',
        'font-size: 13px; font-family: monospace;'
      );
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
  @import '../styles/glitch.css';
  @import '../styles/sections.css';
</style>
