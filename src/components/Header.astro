---
const navItems = [
  { label: 'About', href: '#about' },
  { label: 'Projects', href: '#projects' },
  { label: 'Activities', href: '#activities' },
  { label: 'Awards', href: '#awards' },
  { label: 'Contact', href: 'mailto:01futabato10@gmail.com' },
];
---

<header class="header">
  <a href="/" class="header__logo">futabato</a>
  <input type="checkbox" id="nav-toggle" class="header__toggle" aria-label="Toggle navigation" />
  <label for="nav-toggle" class="header__hamburger" aria-hidden="true">
    <span></span>
    <span></span>
    <span></span>
  </label>
  <nav class="header__nav">
    {navItems.map((item) => (
      <a href={item.href}>{item.label}</a>
    ))}
  </nav>
</header>
