---
/**
 * Hacking boot sequence overlay.
 * Shows a terminal-style animation on first load, then reveals the portfolio.
 */
---

<div class="boot" id="boot" aria-hidden="true">
  <div class="boot__terminal">
    <div class="boot__lines" id="boot-lines"></div>
    <span class="boot__cursor">_</span>
  </div>
</div>

<style>
  .boot {
    position: fixed;
    inset: 0;
    z-index: 99999;
    background: #0a0a08;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.6s ease;
  }

  .boot--done {
    opacity: 0;
    pointer-events: none;
  }

  .boot__terminal {
    max-width: 600px;
    width: 90%;
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(0.7rem, 1.5vw, 0.85rem);
    color: #15ff00;
    line-height: 1.8;
  }

  .boot__line {
    opacity: 0;
    white-space: pre-wrap;
    word-break: break-all;
  }

  .boot__line--visible {
    opacity: 1;
  }

  .boot__line--amber {
    color: #ffb000;
  }

  .boot__line--red {
    color: #ff0000;
  }

  .boot__line--dim {
    color: #555550;
  }

  .boot__line--access {
    color: #15ff00;
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    font-weight: 700;
    margin-top: 0.5rem;
  }

  .boot__cursor {
    animation: cursor-blink 0.6s infinite;
  }

  @keyframes cursor-blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .boot {
      display: none;
    }
  }
</style>

<script>
  const boot = document.getElementById('boot');
  const linesContainer = document.getElementById('boot-lines');

  if (boot && linesContainer && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    // Prevent scrolling during boot
    document.body.style.overflow = 'hidden';

    function randomHex(len: number): string {
      return Array.from({ length: len }, () =>
        Math.floor(Math.random() * 16).toString(16)
      ).join('');
    }

    function randomIP(): string {
      return `${Math.floor(Math.random() * 255)}.${Math.floor(Math.random() * 255)}.${Math.floor(Math.random() * 255)}.${Math.floor(Math.random() * 254) + 1}`;
    }

    const sequence: { text: string; cls?: string; delay: number }[] = [
      { text: '> Initializing connection...', delay: 0 },
      { text: `  Target: futabato.github.io (${randomIP()})`, cls: 'dim', delay: 300 },
      { text: `  Protocol: SSH-2.0 | Port: 443`, cls: 'dim', delay: 150 },
      { text: '> Bypassing firewall...', delay: 400 },
      { text: `  Rule #${Math.floor(Math.random() * 900) + 100}: BYPASSED`, cls: 'dim', delay: 200 },
      { text: `  Rule #${Math.floor(Math.random() * 900) + 100}: BYPASSED`, cls: 'dim', delay: 120 },
      { text: `  Rule #${Math.floor(Math.random() * 900) + 100}: BYPASSED`, cls: 'dim', delay: 100 },
      { text: '> Injecting payload...', delay: 350 },
      { text: `  0x${randomHex(8)} -> 0x${randomHex(8)}`, cls: 'dim', delay: 150 },
      { text: `  0x${randomHex(8)} -> 0x${randomHex(8)}`, cls: 'dim', delay: 100 },
      { text: `  Checksum: ${randomHex(16)}`, cls: 'dim', delay: 120 },
      { text: '> Authenticating...', delay: 400 },
      { text: `  User: futabato`, cls: 'dim', delay: 200 },
      { text: `  Token: ****${randomHex(4)}`, cls: 'dim', delay: 150 },
      { text: '  Status: VERIFIED', cls: 'amber', delay: 300 },
      { text: '', delay: 200 },
      { text: '> Access granted.', cls: 'access', delay: 500 },
    ];

    let i = 0;
    let totalDelay = 400; // initial pause

    for (const step of sequence) {
      totalDelay += step.delay;
      const capturedIndex = i;
      const capturedStep = step;

      setTimeout(() => {
        const line = document.createElement('div');
        line.className = 'boot__line';
        if (capturedStep.cls) line.classList.add(`boot__line--${capturedStep.cls}`);
        line.textContent = capturedStep.text;
        linesContainer!.appendChild(line);
        // Trigger reflow then show
        requestAnimationFrame(() => line.classList.add('boot__line--visible'));
        // Auto-scroll terminal
        linesContainer!.scrollTop = linesContainer!.scrollHeight;
      }, totalDelay);

      i++;
    }

    // Dismiss after sequence completes
    totalDelay += 800;
    setTimeout(() => {
      boot.classList.add('boot--done');
      document.body.style.overflow = '';
      // Remove from DOM after fade
      setTimeout(() => boot.remove(), 600);
    }, totalDelay);
  } else if (boot) {
    // Reduced motion: remove immediately
    boot.remove();
  }
</script>
