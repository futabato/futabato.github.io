---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import GlitchText from '../components/GlitchText.astro';
import ProjectCard from '../components/ProjectCard.astro';
import TimelineItem from '../components/TimelineItem.astro';
import GlitchPopup from '../components/GlitchPopup.astro';
import Footer from '../components/Footer.astro';
import data from '../data/portfolio.json';
---

<BaseLayout title="futabato — Adversarial Portfolio">
  <Header />
  <main class="main-content">
    <Hero />

    <!-- About / Education -->
    <Section id="about">
      <GlitchText text="Education" />
      <div class="info-list">
        {data.education.map((edu) => (
          <div class="info-list__item">
            <div class="info-list__item-title">{edu.institution}</div>
            <div class="info-list__item-detail">
              {edu.department} — {edu.location}<br />
              {edu.period}
              {edu.note && <><br />{edu.note}</>}
            </div>
          </div>
        ))}
      </div>
    </Section>

    <!-- Projects -->
    <Section id="projects">
      <GlitchText text="Projects" />
      <div class="projects-grid">
        {data.projects.map((p) => (
          <ProjectCard name={p.name} description={p.description} blog={p.blog} repo={p.repo} />
        ))}
      </div>
    </Section>

    <!-- Activities Timeline -->
    <Section id="activities">
      <GlitchText text="Activities" />
      <div class="timeline">
        {data.activities.map((a) => (
          <TimelineItem year={a.year} items={a.items} />
        ))}
      </div>
    </Section>

    <!-- Awards -->
    <Section id="awards">
      <GlitchText text="Awards" />
      <div class="info-list">
        {data.awards.map((award) => (
          <div class="info-list__item">
            <div class="info-list__item-title">{award.name}</div>
            <div class="info-list__item-detail">{award.detail}</div>
          </div>
        ))}
      </div>
    </Section>

    <!-- Certificates -->
    <Section id="certificates">
      <GlitchText text="Certificates" />
      <div class="info-list">
        {data.certificates.map((cert) => (
          <div class="info-list__item">
            <div class="info-list__item-title">{cert.name}</div>
            <div class="info-list__item-detail">{cert.date}</div>
          </div>
        ))}
      </div>
    </Section>

    <!-- Achievements & Scholarship -->
    <Section id="achievements">
      <GlitchText text="Achievements" />
      <div class="info-list">
        {data.achievements.map((a) => (
          <div class="info-list__item">
            <div class="info-list__item-title">{a.name}</div>
            <div class="info-list__item-detail">{a.date}</div>
          </div>
        ))}
        <div class="info-list__item">
          <div class="info-list__item-title">{data.scholarship.name}</div>
          <div class="info-list__item-detail">{data.scholarship.type} — {data.scholarship.period}</div>
        </div>
      </div>
    </Section>
  </main>

  <Footer />

  <!-- Glitch Popups -->
  <GlitchPopup />

  <!-- Screen tear lines -->
  <div class="screen-tear" id="screen-tear-1" aria-hidden="true"></div>
  <div class="screen-tear" id="screen-tear-2" aria-hidden="true"></div>

  <!-- ===== All interactive JS ===== -->
  <script>
    // --- Reduced motion check ---
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // --- 0. Film grain (canvas noise) ---
    if (!prefersReducedMotion) {
      const grainCanvas = document.getElementById('film-grain') as HTMLCanvasElement;
      if (grainCanvas) {
        const ctx = grainCanvas.getContext('2d');
        function resizeGrain() {
          // Render at half resolution for performance
          grainCanvas.width = window.innerWidth / 2;
          grainCanvas.height = window.innerHeight / 2;
        }
        resizeGrain();
        window.addEventListener('resize', resizeGrain);

        function drawGrain() {
          if (!ctx) return;
          const w = grainCanvas.width;
          const h = grainCanvas.height;
          const imageData = ctx.createImageData(w, h);
          const data = imageData.data;
          for (let i = 0; i < data.length; i += 4) {
            const v = Math.random() * 255;
            data[i] = v;
            data[i + 1] = v;
            data[i + 2] = v;
            data[i + 3] = 255;
          }
          ctx.putImageData(imageData, 0, 0);
          requestAnimationFrame(drawGrain);
        }
        drawGrain();
      }
    }

    // --- 0b. VHS tracking bands ---
    if (!prefersReducedMotion) {
      const vhsBand1 = document.getElementById('vhs-tracking-1');
      const vhsBand2 = document.getElementById('vhs-tracking-2');

      function triggerVhsBand() {
        const el = Math.random() > 0.5 ? vhsBand1 : vhsBand2;
        if (!el) return;
        el.style.top = `${Math.random() * 100}vh`;
        el.classList.remove('vhs-tracking--active');
        void el.offsetWidth;
        el.classList.add('vhs-tracking--active');
      }

      function scheduleVhsBand() {
        const delay = 2000 + Math.random() * 5000;
        setTimeout(() => {
          triggerVhsBand();
          scheduleVhsBand();
        }, delay);
      }
      scheduleVhsBand();
    }

    // --- 0c. VHS timestamp ---
    {
      const dateEl = document.getElementById('vhs-date');
      if (dateEl) {
        function updateVhsDate() {
          const now = new Date();
          const y = now.getFullYear();
          const m = String(now.getMonth() + 1).padStart(2, '0');
          const d = String(now.getDate()).padStart(2, '0');
          const h = String(now.getHours()).padStart(2, '0');
          const min = String(now.getMinutes()).padStart(2, '0');
          const s = String(now.getSeconds()).padStart(2, '0');
          dateEl!.textContent = `${y}.${m}.${d}  ${h}:${min}:${s}`;
        }
        updateVhsDate();
        setInterval(updateVhsDate, 1000);
      }
    }

    // --- 0d. OZ Layer (Summer Wars — periodic Love Machine attacks) ---
    if (!prefersReducedMotion) {
      const ozGrid = document.getElementById('oz-grid');
      const ozAvatars = document.getElementById('oz-avatars');
      const ozLovemachine = document.getElementById('oz-lovemachine');
      const ozRedwash = document.getElementById('oz-redwash');
      const avatarVariants = ['white', 'blue', 'pink', 'yellow', 'green'];
      const spawnedAvatars: HTMLDivElement[] = [];

      // Invasion state — ratchets up, never goes back down
      let invasionLevel = 0;    // 0..1
      const MAX_ATTACKS = 5;
      let attackCount = 0;

      function randomBetween(min: number, max: number) {
        return min + Math.random() * (max - min);
      }

      function spawnAvatar(absorbed: boolean) {
        if (!ozAvatars) return;
        const avatar = document.createElement('div');
        const size = absorbed ? randomBetween(10, 36) : randomBetween(8, 28);
        const variant = absorbed ? 'absorbed' : avatarVariants[Math.floor(Math.random() * avatarVariants.length)];
        avatar.className = `oz-avatar oz-avatar--${variant}`;
        avatar.style.width = `${size}px`;
        avatar.style.height = `${size}px`;
        avatar.style.left = `${randomBetween(3, 97)}%`;
        avatar.style.top = `${randomBetween(3, 92)}%`;
        avatar.style.animationDelay = `${randomBetween(0, 6)}s`;
        avatar.style.animationDuration = `${randomBetween(6, 14)}s`;
        requestAnimationFrame(() => {
          avatar.style.opacity = `${randomBetween(0.2, absorbed ? 0.65 : 0.45)}`;
        });
        ozAvatars.appendChild(avatar);
        spawnedAvatars.push(avatar);
      }

      function absorbAvatars() {
        spawnedAvatars.forEach((av) => {
          if (!av.classList.contains('oz-avatar--absorbed')) {
            av.classList.remove(
              'oz-avatar--white', 'oz-avatar--blue', 'oz-avatar--pink',
              'oz-avatar--yellow', 'oz-avatar--green'
            );
            av.classList.add('oz-avatar--absorbed');
            av.style.opacity = `${randomBetween(0.35, 0.65)}`;
          }
        });
      }

      function applyInvasion() {
        document.documentElement.style.setProperty('--oz-invasion', `${invasionLevel}`);
        if (ozGrid) ozGrid.style.opacity = `${Math.min(invasionLevel * 1.5, 0.8)}`;
        if (ozLovemachine) ozLovemachine.style.opacity = `${invasionLevel}`;
        if (ozRedwash) ozRedwash.style.opacity = `${Math.max(0, invasionLevel - 0.3)}`;
      }

      // Spawn initial peaceful OZ avatars after 8s
      setTimeout(() => {
        for (let i = 0; i < 10; i++) spawnAvatar(false);
        if (ozGrid) {
          ozGrid.style.opacity = '0.3';
        }
      }, 8000);

      function loveMachineAttack() {
        if (attackCount >= MAX_ATTACKS) return;
        attackCount++;

        // Ratchet up invasion level
        invasionLevel = Math.min(attackCount / MAX_ATTACKS, 1);

        // Flash effect — brief bright red flash
        const flash = document.createElement('div');
        flash.style.cssText = `
          position: fixed; inset: 0; z-index: 9999;
          background: rgba(255, 0, 0, 0.15);
          pointer-events: none;
          animation: lm-flash 0.4s ease-out forwards;
        `;
        document.body.appendChild(flash);
        setTimeout(() => flash.remove(), 500);

        // Screen shake
        document.body.style.transition = 'transform 0.05s';
        let shakeCount = 0;
        const shakeInterval = setInterval(() => {
          shakeCount++;
          const x = (Math.random() - 0.5) * 6;
          const y = (Math.random() - 0.5) * 6;
          document.body.style.transform = `translate(${x}px, ${y}px)`;
          if (shakeCount > 6) {
            clearInterval(shakeInterval);
            document.body.style.transform = '';
          }
        }, 50);

        // Absorb some avatars + spawn red ones
        absorbAvatars();
        const redCount = 4 + Math.floor(Math.random() * 6);
        for (let i = 0; i < redCount; i++) {
          setTimeout(() => spawnAvatar(true), Math.random() * 800);
        }

        // Apply persistent color invasion
        applyInvasion();

        // Schedule next attack (if not maxed)
        if (attackCount < MAX_ATTACKS) {
          const nextDelay = 20000 + Math.random() * 25000; // 20–45s
          setTimeout(loveMachineAttack, nextDelay);
        }
      }

      // First attack after 25–40s
      setTimeout(loveMachineAttack, 25000 + Math.random() * 15000);

      // Inject flash keyframe
      const style = document.createElement('style');
      style.textContent = `
        @keyframes lm-flash {
          0% { opacity: 1; }
          100% { opacity: 0; }
        }
      `;
      document.head.appendChild(style);
    }

    // --- 1. Scroll fade-in observer ---
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 }
    );
    document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));

    // --- 2. Cursor trail ---
    if (!prefersReducedMotion) {
      const TRAIL_COUNT = 8;
      const colors = ['#15ff00', '#ffb000', '#0051ff', '#15ff00'];
      const dots: HTMLDivElement[] = [];
      const positions: { x: number; y: number }[] = [];

      for (let i = 0; i < TRAIL_COUNT; i++) {
        const dot = document.createElement('div');
        dot.className = 'cursor-dot';
        dot.style.background = colors[i % colors.length];
        dot.style.width = `${6 - i * 0.5}px`;
        dot.style.height = `${6 - i * 0.5}px`;
        document.body.appendChild(dot);
        dots.push(dot);
        positions.push({ x: -100, y: -100 });
      }

      let mouseX = -100;
      let mouseY = -100;

      document.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
      });

      function animateTrail() {
        positions[0].x += (mouseX - positions[0].x) * 0.3;
        positions[0].y += (mouseY - positions[0].y) * 0.3;

        for (let i = 1; i < TRAIL_COUNT; i++) {
          positions[i].x += (positions[i - 1].x - positions[i].x) * 0.25;
          positions[i].y += (positions[i - 1].y - positions[i].y) * 0.25;
        }

        for (let i = 0; i < TRAIL_COUNT; i++) {
          const dot = dots[i];
          dot.style.left = `${positions[i].x}px`;
          dot.style.top = `${positions[i].y}px`;
          dot.style.opacity = `${1 - i / TRAIL_COUNT}`;
        }

        requestAnimationFrame(animateTrail);
      }
      requestAnimationFrame(animateTrail);
    }

    // --- 3. Screen tearing ---
    if (!prefersReducedMotion) {
      const tear1 = document.getElementById('screen-tear-1');
      const tear2 = document.getElementById('screen-tear-2');

      function triggerTear() {
        const el = Math.random() > 0.5 ? tear1 : tear2;
        if (!el) return;
        el.style.top = `${Math.random() * 100}vh`;
        el.classList.remove('screen-tear--active');
        void el.offsetWidth; // reflow
        el.classList.add('screen-tear--active');
      }

      function scheduleTear() {
        const delay = 3000 + Math.random() * 6000;
        setTimeout(() => {
          triggerTear();
          scheduleTear();
        }, delay);
      }
      scheduleTear();
    }

    // --- 4. Random popups on scroll ---
    if (!prefersReducedMotion) {
      const popups = document.querySelectorAll<HTMLElement>('.popup');
      const popupTriggered = new Set<number>();
      const sectionEls = document.querySelectorAll<HTMLElement>('.section');
      const sectionCount = sectionEls.length;

      // Map each popup to a section index for triggering
      const popupSectionMap: Map<number, number> = new Map();
      popups.forEach((_, i) => {
        popupSectionMap.set(i, Math.min(i, sectionCount - 1));
      });

      const popupObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const secIdx = Array.from(sectionEls).indexOf(entry.target as HTMLElement);

            popupSectionMap.forEach((mappedSec, popupIdx) => {
              if (mappedSec === secIdx && !popupTriggered.has(popupIdx)) {
                popupTriggered.add(popupIdx);
                const popup = popups[popupIdx];
                if (!popup) return;

                // Random position — avoid taskbar at bottom
                const maxX = window.innerWidth - 300;
                const maxY = window.innerHeight - 200;
                popup.style.left = `${60 + Math.random() * Math.max(maxX - 60, 100)}px`;
                popup.style.top = `${40 + Math.random() * Math.max(maxY - 40, 100)}px`;

                setTimeout(() => {
                  popup.classList.add('popup--visible');
                }, 300 + Math.random() * 500);
              }
            });
          });
        },
        { threshold: 0.3 }
      );

      sectionEls.forEach((sec) => popupObserver.observe(sec));

      // Close popups on OK or X click
      document.querySelectorAll('.popup__ok, .popup__close').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          const popup = (e.target as HTMLElement).closest('.popup');
          if (popup) popup.classList.remove('popup--visible');
        });
      });
    }
  </script>
</BaseLayout>
